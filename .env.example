# Database
POSTGRES_USER=timeline
POSTGRES_PASSWORD=changeme
POSTGRES_DB=timeline
DATABASE_URL=postgresql+asyncpg://timeline:changeme@postgres:5432/timeline

# Auth
JWT_SECRET=replace-with-a-long-random-secret

# Initial user (created automatically on first startup)
APP_USERNAME=your_username
APP_PASSWORD=your_password

# Google Maps (frontend)
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Google Drive sync (importer)
# Paste the entire service account JSON as a single-line string
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"..."}
GOOGLE_DRIVE_FOLDER_ID=your-google-drive-folder-id
# Sync interval in seconds (default: 900 = 15 minutes)
SYNC_INTERVAL_SECONDS=900
